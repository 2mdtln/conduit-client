{
	"schemaVersion": 1,
	"id": "conduit-client",
	"version": "${version}",
	"name": "Conduit Client",
	"description": "hey :)",
	"authors": [
		"2mdtln"
	],
	"contact": {
		"homepage": "https://github.com/2mdtln/conduit-client",
		"sources": "https://github.com/2mdtln/conduit-client"
	},
	"license": "CC0-1.0",
	"icon": "assets/conduit-client/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "com.twomdtln.ConduitClient",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "com.twomdtln.client.ConduitClientClient",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
			{
				"value": "com.twomdtln.client.ConduitModMenuIntegration",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		{
			"config": "conduit-client.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}
